<!--
    AndroidManifest.xml - 阿里云一键登录 Android 原生模块清单文件
    声明所需权限和 SDK 相关组件配置
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ============ 阿里云一键登录所需权限 ============ -->

    <!-- 网络权限：必须，用于与阿里云服务器通信获取 Token -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 读取手机状态：用于检测当前运营商网络环境是否支持一键登录 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 网络状态：用于检测当前网络连接状态 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>

        <!-- 融合认证：号码认证授权页 -->
        <activity
            android:name="com.alicom.fusion.auth.numberauth.FusionNumberAuthActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:screenOrientation="behind" />

        <!-- 融合认证：上行短信页 -->
        <activity
            android:name="com.alicom.fusion.auth.upsms.AlicomFusionUpSmsActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:screenOrientation="behind" />

        <!-- 融合认证：短信验证码页 -->
        <activity
            android:name="com.alicom.fusion.auth.smsauth.FusionSmsActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:screenOrientation="behind" />

        <!-- 融合认证：图形验证码页 -->
        <activity
            android:name="com.alicom.fusion.auth.graphauth.FusionGraphAuthActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:screenOrientation="behind" />

        <!-- 融合认证：号码认证底层 Activity（来自 alicloud-android-dypns） -->
        <activity
            android:name="com.mobile.auth.gatewayauth.LoginAuthActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="behind"
            android:theme="@style/authsdk_activity_dialog" />

        <activity
            android:name="com.mobile.auth.gatewayauth.PrivacyDialogActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="behind"
            android:theme="@style/authsdk_activity_dialog" />

    </application>
</manifest>
