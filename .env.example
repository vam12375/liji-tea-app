# ================================================
# 支付宝沙箱 / 正式环境 必填配置
# ================================================

# 支付宝开放平台 App ID（沙箱在沙箱后台获取，正式环境在开放平台获取）
ALIPAY_APP_ID=2021025368541214

# RSA2 私钥（PEM 格式，带 ----BEGIN RSA PRIVATE KEY---- 头尾）
# ⚠️ 仅保存在服务端！禁止写入客户端代码或暴露给前端！
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBA...\n-----END RSA PRIVATE KEY-----"

# 支付宝公钥（用于验签回调通知，从开放平台获取）
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqh...\n-----END PUBLIC KEY-----"

# 沙箱网关（沙箱环境）
ALIPAY_GATEWAY=https://your-domain.com/gateway.do
# 正式网关（生产环境）
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 支付宝异步通知回调地址（必须是公网可访问的 HTTPS 地址）
# 本地开发可用 ngrok/内网穿透工具生成临时公网地址
# 格式：https://your-domain.com/functions/v1/alipay-notify
ALIPAY_NOTIFY_URL=https://your-domain.com/functions/v1/alipay-notify

# 商户 PID（正式环境必填，沙箱可选）
# ALIPAY_SELLER_ID=2088123456789012

# ================================================
# Supabase Edge Functions 运行时配置（本地开发用）
# 生产环境请在 Supabase Dashboard → Edge Functions → Secrets 中配置
# ================================================
SUPABASE_URL=https://your-domain.com.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ================================================
# 客户端 Expo 环境变量（前端可访问，仅限 PUBLIC_ 前缀）
# ================================================
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 前端分享用的公网站点地址（可选）
# 配置后文章分享会同时带上 H5 链接与 App 深链
# 示例：https://tea.example.com
EXPO_PUBLIC_WEB_URL=

# 支付渠道开关（客户端读取）

EXPO_PUBLIC_PAYMENT_ALIPAY_ENABLED=true
EXPO_PUBLIC_PAYMENT_WECHAT_ENABLED=false

# 阿里云一键登录 AppKey（在阿里云数字验证码控制台获取）
ALI_APP_KEY=

# 阿里云融合认证模板 ID（在阿里云数字验证码控制台 → 融合认证 → 模板管理 中获取）
EXPO_PUBLIC_ALI_TEMPLATE_ID=

# 当前环境标记（客户端读取，用于展示）
EXPO_PUBLIC_PAYMENT_ENV=sandbox
