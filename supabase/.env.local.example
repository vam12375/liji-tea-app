# ================================================
# Supabase Edge Functions 本地运行时环境变量
# ================================================
# 复制此文件为 .env.local 并填入真实值
# 本地运行 edge fn 时使用：supabase functions serve --env-file ./supabase/.env.local

SUPABASE_URL=https://your.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ================================================
# 支付宝配置（沙箱）
# ================================================
ALIPAY_APP_ID=your_sandbox_app_id
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour_public_key_here\n-----END PUBLIC KEY-----"
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-ngrok-url.supabase.co/functions/v1/alipay-notify
# ALIPAY_SELLER_ID=your_sandbox_seller_id
