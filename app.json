{
  "expo": {
    "name": "李记茶",
    "slug": "liji-tea-app",
    "owner": "vam12375",
    "version": "4.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/liji-logo.png",
    "scheme": "lijiteaapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/liji-logo.png"
    },
    "android": {
      "package": "com.liji.teaapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/liji-logo.png",
        "monochromeImage": "./assets/images/liji-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2C2C2C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "autolinking": {
      "nativeModulesDir": "./modules"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9a2b0a1d-b43e-4840-a97b-2b8e4e8b88d0"
      }
    }
  }
}
